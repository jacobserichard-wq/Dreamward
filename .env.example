# Dreamward — environment variable template
#
# Copy this file to `.env.local` and fill in the real values. The
# `.env.local` file is gitignored; never commit secrets.
#
# Production values live in Vercel → Project → Settings → Environment
# Variables. This file documents what's required + where to grab each
# value; it's not loaded by anything.
#
# Last updated: sub-session 23 hygiene pass (2026-05-20).

# ============================================================
# Core — required for the app to boot
# ============================================================

# Postgres connection string. In dev: same Railway prod DB (read the
# connection string from Railway → PostgreSQL service → Variables tab).
# In prod (Vercel): same value pasted into Vercel env vars.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Full origin of the deployment. NextAuth callback URL routing depends on
# this. In dev: http://localhost:3000. In prod: https://godreamward.com.
NEXTAUTH_URL=http://localhost:3000

# Random secret used by NextAuth to encrypt session JWTs. Generate via:
#   openssl rand -base64 32
# Must be the same across all instances of the same deployment.
NEXTAUTH_SECRET=

# ============================================================
# Google OAuth — required for sign-in + Gmail integration (Pro)
# ============================================================
# Grab from Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client IDs → godreamward.com.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Anthropic Claude — required for AI extraction + classification
# ============================================================
# Get from console.anthropic.com → API keys.
ANTHROPIC_API_KEY=

# ============================================================
# Resend — required for transactional email
# ============================================================
# Get from resend.com → API keys. Sender (hello@godreamward.com) is
# configured in Resend's dashboard, not here.
# Used by: welcome / trial-expiring / payment-failed / Pro reminder
# crons, Phase 6 AR reminders, Phase 7a CPA summary handoff.
RESEND_API_KEY=

# ============================================================
# Stripe — required for billing
# ============================================================
# Get from dashboard.stripe.com → Developers → API keys.
# Use the test-mode keys (sk_test_...) for local dev; live-mode
# keys (sk_live_...) only in Vercel production.
STRIPE_SECRET_KEY=

# Get from dashboard.stripe.com → Developers → Webhooks → endpoint
# signing secret. Different secret per webhook endpoint (local CLI
# webhook vs the prod /api/stripe/webhook endpoint).
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Google Maps — required for Phase 4 event mileage
# ============================================================
# Distance Matrix API key. Enable the API in Google Cloud Console
# first (APIs & Services → Library → Distance Matrix API → Enable),
# then create a server-restricted key in Credentials.
GOOGLE_MAPS_API_KEY=

# ============================================================
# Cron auth — required for the daily reminder + reclassify crons
# ============================================================
# Shared secret between Vercel's cron scheduler and /api/cron.
# Generate via:
#   openssl rand -hex 32
# Same value in Vercel env vars + the Authorization header Vercel
# Cron sends.
CRON_SECRET=

# ============================================================
# Admin — required for admin dashboard access
# ============================================================
# Comma-separated allowlist of admin email addresses. Users with
# matching session emails see /admin and the admin client detail
# views. No comma after the last entry.
ADMIN_EMAILS=jacobse.richard@gmail.com

# ============================================================
# Calendly — required for Phase 1.7 Pro onboarding flow
# ============================================================
# Public Calendly URL (NEXT_PUBLIC_ prefix exposes it to the browser
# bundle — safe because it's a public link anyway). Used by the
# welcome-pro page's embedded scheduler.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/your-event-type

# Webhook signing key from Calendly → Webhooks → endpoint details.
# Used by /api/calendly/webhook for HMAC-SHA256 signature verification.
# (See commit14.2-report.md for the Calendly Production setup steps.)
CALENDLY_WEBHOOK_SIGNING_KEY=

# ============================================================
# Etsy — required for the Etsy integration (Open API v3)
# ============================================================
# From etsy.com/developers → Your apps → your app.
# ETSY_API_KEY is the "Keystring" (also the OAuth client_id).
ETSY_API_KEY=
# ETSY_SHARED_SECRET is the "Shared Secret" (behind the eye icon on
# the same page). Etsy has REQUIRED this in the x-api-key header
# since Feb 9 2026 — the header is sent as `keystring:shared_secret`.
# Without it, every API call 403s with "Shared secret is required in
# x-api-key header" even though OAuth (which only uses the keystring)
# succeeds. See lib/etsy.ts etsyApiKeyHeader().
ETSY_SHARED_SECRET=
